# --- Server ---
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# --- MongoDB ---
# Local: mongodb://127.0.0.1:27017/hayatoolings
# Atlas example: mongodb+srv://<user>:<pass>@cluster.mongodb.net/hayatoolings?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/hayatoolings

# --- Admin auth (used by seed script) ---
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d
ADMIN_EMAIL=admin@hayatoolings.com
ADMIN_PASSWORD=Admin@12345
ADMIN_NAME=Haya Admin

# --- Currency conversion (1 INR = X) ---
# Used to compute USD/EUR display amounts from INR base prices.
# Update these to match the amounts configured on your PayGlocal payment buttons,
# OR keep as live-ish reference rates and reconcile on the PayGlocal dashboard.
INR_TO_USD=0.012
INR_TO_EUR=0.011

# --- PayGlocal ---
# Payment Button IDs (Simple Pay) shared by the merchant.
PAYGLOCAL_INR_PB_ID=pb_fnHmd4NKIcGw
PAYGLOCAL_USD_PB_ID=pb_91zEg1FlHbzd
PAYGLOCAL_EUR_PB_ID=pb_F8ErdVORsXTK
# Optional: PayGlocal API credentials for server-to-server (PayCollect/PayDirect).
# Leave empty if you only use the Payment Button embed.
PAYGLOCAL_API_BASE=https://api.uat.payglocal.in
PAYGLOCAL_MERCHANT_ID=
PAYGLOCAL_API_KEY=
# Path to PayGlocal's RSA public key (PEM). Used to verify any JWT/JWS that
# PayGlocal appends to the return URL. Leave blank to skip verification.
PAYGLOCAL_PUBLIC_KEY_FILE=./keys/payglocal_public.pem
# Webhook signing secret (configure on PayGlocal dashboard, optional).
PAYGLOCAL_WEBHOOK_SECRET=
